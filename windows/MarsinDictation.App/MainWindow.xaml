<Window x:Class="MarsinDictation.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MarsinDictation — Settings"
        Width="400" Height="300"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="MarsinDictation"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16" />
            <TextBlock Text="Settings will be implemented in Phase 5."
                       FontSize="14"
                       Foreground="Gray"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8" />
            <TextBlock Text="Dictation: Ctrl+Alt+Space"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4" />
            <TextBlock Text="Recovery: Alt+Shift+Z"
                       FontSize="14"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
