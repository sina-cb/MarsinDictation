<Window x:Class="MarsinDictation.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MarsinDictation Settings"
        Width="480" Height="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="MarsinDictation" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Provider Selection -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="Transcription Provider" FontWeight="SemiBold" Margin="0,0,0,8" />
            <RadioButton x:Name="RadioEmbedded" Content="Embedded Whisper (local, free)" Margin="0,0,0,5" Checked="Provider_Checked"/>
            <RadioButton x:Name="RadioLocalAI" Content="LocalAI (local server)" Margin="0,0,0,5" Checked="Provider_Checked"/>
            <RadioButton x:Name="RadioOpenAI" Content="OpenAI (cloud)" Checked="Provider_Checked"/>
        </StackPanel>

        <!-- Dynamic Provider Settings -->
        <Border Grid.Row="2" BorderBrush="#EAEAEA" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,20">
            <StackPanel>
                <Grid x:Name="PanelEmbedded" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Embedded Whisper" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock Text="Model file" Foreground="Gray" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtWhisperModel" Text="ggml-large-v3-turbo-q5_0.bin" Margin="0,0,0,5"/>
                        <TextBlock Text="Model is stored in %LOCALAPPDATA%\MarsinDictation\models\" FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="PanelLocalAI" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="LocalAI" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock Text="Endpoint" Foreground="Gray" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtLocalAIEndpoint" Text="http://localhost:3850" Margin="0,0,0,10"/>
                        <TextBlock Text="Model" Foreground="Gray" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtLocalAIModel" Text="whisper-1" />
                    </StackPanel>
                </Grid>

                <Grid x:Name="PanelOpenAI" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="OpenAI" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock Text="API Key" Foreground="Gray" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="TxtOpenAIKey" Margin="0,0,0,10" />
                        <TextBlock Text="Model" Foreground="Gray" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ComboOpenAIModel">
                            <ComboBoxItem Content="gpt-4o-mini-transcribe" />
                            <ComboBoxItem Content="gpt-4o-transcribe" />
                            <ComboBoxItem Content="whisper-1" />
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- General Settings -->
        <StackPanel Grid.Row="3" Margin="0,0,0,20">
            <TextBlock Text="General" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBlock Text="Language (ISO 639-1)" Foreground="Gray" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtLanguage" Text="en" Width="60" HorizontalAlignment="Left" Margin="0,0,0,10"/>
        </StackPanel>

        <!-- Hotkeys Summary -->
        <StackPanel Grid.Row="4" Margin="0,0,0,20">
            <TextBlock Text="Hotkeys" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Grid Margin="0,0,0,5">
                <TextBlock Text="Dictation" Foreground="Gray" HorizontalAlignment="Left"/>
                <TextBlock Text="Ctrl+Win (Hold)" FontFamily="Consolas" HorizontalAlignment="Right"/>
            </Grid>
            <Grid>
                <TextBlock Text="Recovery" Foreground="Gray" HorizontalAlignment="Left"/>
                <TextBlock Text="Alt+Shift+Z" FontFamily="Consolas" HorizontalAlignment="Right"/>
            </Grid>
        </StackPanel>

        <!-- Apply Button & Status -->
        <Grid Grid.Row="5">
            <TextBlock x:Name="TxtStatus" Text="Settings saved." Foreground="Green" VerticalAlignment="Center" Visibility="Hidden"/>
            <Button Content="Apply" Width="80" Height="30" HorizontalAlignment="Right" Click="BtnApply_Click"/>
        </Grid>
    </Grid>
</Window>
