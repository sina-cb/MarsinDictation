# MarsinDictation Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Transcription provider: embedded, localai, or openai (embedded is default)
MARSIN_TRANSCRIPTION_PROVIDER=embedded

# Language for transcription (ISO 639-1 code, e.g. en, es, fr, de, zh, ja)
MARSIN_LANGUAGE=en

# Embedded Whisper (default — in-process whisper.cpp, no server needed)
# Model file is downloaded on first launch to the platform model directory:
#   macOS:   ~/Library/Application Support/MarsinDictation/models/
#   Windows: %LOCALAPPDATA%\MarsinDictation\models\
MARSIN_WHISPER_MODEL=ggml-base.en.bin

# LocalAI (alternative — requires running LocalAI server)
LOCALAI_ENDPOINT=http://localhost:3840
LOCALAI_MODEL=whisper-large-turbo

# OpenAI (required if provider=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini-transcribe
