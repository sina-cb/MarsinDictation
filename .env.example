# MarsinDictation Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Transcription provider: openai or localai
MARSIN_TRANSCRIPTION_PROVIDER=openai

# OpenAI (required if provider=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini-transcribe

# LocalAI (required if provider=localai)
LOCALAI_ENDPOINT=http://localhost:8080
LOCALAI_MODEL=whisper-1
