# MarsinDictation Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Transcription provider: localai or openai (localai is default)
MARSIN_TRANSCRIPTION_PROVIDER=localai

# Language for transcription (ISO 639-1 code, e.g. en, es, fr, de, zh, ja)
MARSIN_LANGUAGE=en

# LocalAI (default — free, offline, private)
LOCALAI_ENDPOINT=http://localhost:3850
LOCALAI_MODEL=whisper-1

# OpenAI (required if provider=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini-transcribe
